{
  "openapi": "3.1.0",
  "info": {
    "title": "Sanzi Assistant API",
    "description": "三资管理智能问答助手后端 API",
    "version": "0.1.0"
  },
  "paths": {
    "/api/health": {
      "get": {
        "tags": [
          "health"
        ],
        "summary": "Health Check",
        "description": "返回后端基础运行状态。",
        "operationId": "health_check_api_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "type": "object",
                  "title": "Response Health Check Api Health Get"
                }
              }
            }
          }
        }
      }
    },
    "/api/qa/ask": {
      "post": {
        "tags": [
          "qa"
        ],
        "summary": "Ask Question",
        "description": "根据用户问题返回简明、带来源和追问建议的业务回答。",
        "operationId": "ask_question_api_qa_ask_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AskRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AskResponse"
                }
              }
            }
          },
          "422": {
            "description": "参数校验失败",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "服务内部错误",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/chat": {
      "post": {
        "tags": [
          "chat"
        ],
        "summary": "Chat",
        "description": "接收 React 聊天问题，并返回回答、来源和推荐追问。",
        "operationId": "chat_chat_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AskRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AskResponse"
                }
              }
            }
          },
          "422": {
            "description": "参数校验失败",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "服务内部错误",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/chat/stream": {
      "post": {
        "tags": [
          "chat"
        ],
        "summary": "Chat Stream",
        "description": "以 SSE 方式流式返回回答，配合前端打字机效果。",
        "operationId": "chat_stream_chat_stream_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AskRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "SSE 事件流：meta/sources/delta/suggestions/done/error",
            "content": {
              "application/json": {
                "schema": {}
              },
              "text/event-stream": {}
            }
          },
          "422": {
            "description": "参数校验失败",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "服务内部错误",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AskRequest": {
        "properties": {
          "question": {
            "type": "string",
            "maxLength": 500,
            "minLength": 1,
            "title": "Question",
            "description": "用户输入的问题"
          },
          "platform": {
            "$ref": "#/components/schemas/Platform",
            "description": "用户所在终端",
            "default": "pc"
          },
          "session_id": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 80
              },
              {
                "type": "null"
              }
            ],
            "title": "Session Id",
            "description": "可选会话 ID"
          }
        },
        "type": "object",
        "required": [
          "question"
        ],
        "title": "AskRequest",
        "description": "问答接口请求体。"
      },
      "AskResponse": {
        "properties": {
          "answer": {
            "type": "string",
            "title": "Answer"
          },
          "sources": {
            "items": {
              "$ref": "#/components/schemas/Source"
            },
            "type": "array",
            "title": "Sources"
          },
          "suggestions": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Suggestions"
          },
          "trace_id": {
            "type": "string",
            "title": "Trace Id"
          },
          "mode": {
            "type": "string",
            "enum": [
              "llm",
              "local_fallback"
            ],
            "title": "Mode"
          }
        },
        "type": "object",
        "required": [
          "answer",
          "sources",
          "suggestions",
          "trace_id",
          "mode"
        ],
        "title": "AskResponse",
        "description": "问答接口响应体。"
      },
      "ErrorCode": {
        "type": "string",
        "enum": [
          "validation_error",
          "not_found",
          "upstream_error",
          "internal_error"
        ],
        "title": "ErrorCode",
        "description": "统一错误码，前端可基于 code 做差异化处理。"
      },
      "ErrorResponse": {
        "properties": {
          "code": {
            "$ref": "#/components/schemas/ErrorCode",
            "description": "机器可读错误码"
          },
          "message": {
            "type": "string",
            "title": "Message",
            "description": "面向用户的中文提示"
          },
          "trace_id": {
            "type": "string",
            "title": "Trace Id",
            "description": "链路 ID，用于排障"
          },
          "details": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Details",
            "description": "可选的附加字段，如校验错误明细"
          }
        },
        "type": "object",
        "required": [
          "code",
          "message",
          "trace_id"
        ],
        "title": "ErrorResponse",
        "description": "统一错误响应体；所有非 2xx 返回都遵循这个结构。"
      },
      "Platform": {
        "type": "string",
        "enum": [
          "pc",
          "mobile"
        ],
        "title": "Platform",
        "description": "终端类型，用于后端根据 PC 或移动端调整回答长度。"
      },
      "Source": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "title": {
            "type": "string",
            "title": "Title"
          },
          "category": {
            "type": "string",
            "title": "Category"
          },
          "excerpt": {
            "type": "string",
            "title": "Excerpt"
          }
        },
        "type": "object",
        "required": [
          "id",
          "title",
          "category",
          "excerpt"
        ],
        "title": "Source",
        "description": "回答引用的资料来源。"
      }
    }
  }
}