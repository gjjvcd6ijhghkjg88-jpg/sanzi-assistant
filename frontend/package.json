{
  "_comment": "作用：声明前端 React 应用的脚本和依赖，支持本地开发、构建和预览。",
  "name": "sanzi-assistant-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "gen:openapi": "cd ../backend && python -m scripts.export_openapi",
    "gen:api": "openapi-typescript ../docs/openapi.json -o ./src/types/api.d.ts",
    "gen:all": "npm run gen:openapi && npm run gen:api"
  },
  "dependencies": {
    "lucide-react": "1.14.0",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "openapi-typescript": "^7.5.0",
    "prettier": "^3.4.2",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.18.0",
    "vite": "8.0.10"
  }
}
