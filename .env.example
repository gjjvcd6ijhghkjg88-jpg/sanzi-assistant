# 作用：提供后端和前端本地开发所需的环境变量模板，真实密钥不要提交到仓库。

# Backend
APP_NAME=Sanzi Assistant API
APP_ENV=local
ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# Frontend
# 留空时走 Vite proxy（开发期推荐，避免跨域）；部署时填真实后端地址。
VITE_API_BASE_URL=
# Vite proxy 的上游后端地址（仅开发期使用）。
VITE_BACKEND_ORIGIN=http://127.0.0.1:8000

